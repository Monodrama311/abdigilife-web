{
  "name": "abdigilife-web",
  "compatibility_date": "2025-06-09",
  "main": "worker.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    // Run the Worker ahead of static assets so security headers (and the 410
    // spam-URL handling) apply to EVERY response, including HTML pages.
    "run_worker_first": true
  }
}
